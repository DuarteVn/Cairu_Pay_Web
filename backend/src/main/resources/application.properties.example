## Exemplo (SEM credenciais) — copie para application.properties
## Windows (PowerShell):
##   Copy-Item backend/src/main/resources/application.properties.example backend/src/main/resources/application.properties
##
## Ajuste os valores conforme seu ambiente.

spring.application.name=cairupay

# Banco de dados (exemplo)
spring.datasource.url=jdbc:postgresql://localhost:5432/cairupay
spring.datasource.username=postgres
spring.datasource.password=CHANGE_ME

# JPA/Hibernate (exemplo)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

